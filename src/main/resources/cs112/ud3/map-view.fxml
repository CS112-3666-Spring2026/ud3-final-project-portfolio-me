<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0"
            prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cs112.ud3.MapController">

    <top>
        <HBox alignment="CENTER" spacing="60.0" style="-fx-background-color: lightgray; -fx-padding: 15;">
            <children>
                <Label fx:id="goldLabel" text="Gold: 100">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="healthLabel" text="Castle Health: 10">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="waveLabel" text="Wave: 1">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="enemiesRemainingLabel" text="Enemies Remaining: 0">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>


            </children>
        </HBox>
    </top>

    <center>
        <Pane fx:id="gamePane" prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: darkseagreen;">

            <children>
                <Label layoutX="40.0" layoutY="140.0" text="ENEMY START">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>

                <Label layoutX="680.0" layoutY="140.0" text="CASTLE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <Line startX="80.0" startY="220.0" endX="700.0" endY="220.0" strokeWidth="8.0" />

                <Rectangle arcHeight="10.0" arcWidth="10.0" height="80.0" layoutX="700.0" layoutY="180.0" width="60.0" />

                <Button fx:id="towerSpotOne"
                        layoutX="160.0"
                        layoutY="145.0"
                        prefWidth="90.0"
                        prefHeight="28.0"
                        mnemonicParsing="false"
                        onAction="#onTowerSpotClick"
                        text="Tower" />

                <Button fx:id="towerSpotTwo"
                        layoutX="330.0"
                        layoutY="145.0"
                        prefWidth="90.0"
                        prefHeight="28.0"
                        mnemonicParsing="false"
                        onAction="#onTowerSpotClick"
                        text="Tower" />

                <Button fx:id="towerSpotThree"
                        layoutX="500.0"
                        layoutY="145.0"
                        prefWidth="90.0"
                        prefHeight="28.0"
                        mnemonicParsing="false"
                        onAction="#onTowerSpotClick"
                        text="Tower" />

                <Button fx:id="towerSpotFour"
                        layoutX="160.0"
                        layoutY="285.0"
                        prefWidth="90.0"
                        prefHeight="28.0"
                        mnemonicParsing="false"
                        onAction="#onTowerSpotClick"
                        text="Tower" />

                <Button fx:id="towerSpotFive"
                        layoutX="330.0"
                        layoutY="285.0"
                        prefWidth="90.0"
                        prefHeight="28.0"
                        mnemonicParsing="false"
                        onAction="#onTowerSpotClick"
                        text="Tower" />

                <Button fx:id="towerSpotSix"
                        layoutX="500.0"
                        layoutY="285.0"
                        prefWidth="90.0"
                        prefHeight="28.0"
                        mnemonicParsing="false"
                        onAction="#onTowerSpotClick"
                        text="Tower" />
            </children>

        </Pane>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: lightgray; -fx-padding: 15;">
            <children>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBackButtonClick" prefWidth="150.0" text="Back to Title" />
                        <Button fx:id="startWaveButton" mnemonicParsing="false" onAction="#onStartWaveButtonClick" prefWidth="150.0" text="Start Wave" />
                        <Button fx:id="restartButton"
                                mnemonicParsing="false"
                                onAction="#onRestartButtonClick"
                                prefWidth="150.0"
                                text="Restart" />
                    </children>
                </HBox>

                <Label fx:id="messageLabel" text="Place towers and start the wave!" />
            </children>
        </VBox>
    </bottom>

</BorderPane>